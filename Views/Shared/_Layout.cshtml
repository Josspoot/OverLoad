@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - OverLoad</title>
    @* Aplica el tema guardado antes de pintar para evitar el parpadeo. *@
    <script>
        (function () {
            try {
                var t = localStorage.getItem('overload-theme');
                document.documentElement.setAttribute('data-theme',
                    ['aqua', 'dark', 'midnight'].indexOf(t) !== -1 ? t : 'aqua');
            } catch (e) {
                document.documentElement.setAttribute('data-theme', 'aqua');
            }
        })();
    </script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-sm street-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">OVERLOAD</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-center">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link street-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link street-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Librería</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link street-nav-link" asp-area="" asp-controller="Home" asp-action="Tracker">Tracker</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link street-nav-link" asp-area="" asp-controller="Calculadora" asp-action="Index">Calculadora</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link street-nav-link" asp-area="" asp-controller="Bitacora" asp-action="Index">Bitácora</a>
                    </li>
                </ul>
            </div>

            <button type="button" class="settings-gear" id="settingsGear" title="Configuración" aria-label="Abrir configuración">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"></circle>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
                </svg>
            </button>
        </div>
    </nav>
</header>

<main role="main">
    @RenderBody()
</main>

<footer class="street-footer text-center">
    <div class="container">
        <small>&copy; 2026 - OVERLOAD - LIFT HEAVY. STAY RAW.</small>
    </div>
</footer>

@* ===== Barra lateral de configuración (temas + cuenta) ===== *@
<div class="settings-overlay" id="settingsOverlay"></div>
<aside class="settings-panel" id="settingsPanel" aria-label="Configuración">
    <div class="settings-head">
        <h5>Configuración</h5>
        <button type="button" class="settings-close" id="settingsClose" aria-label="Cerrar">&times;</button>
    </div>

    <p class="settings-section-title">Tema de la aplicación</p>

    <button type="button" class="theme-option" data-theme="aqua">
        <span class="theme-swatch" style="background: linear-gradient(135deg,#e9f3fc,#cfe4f5); --sw-accent:#3A8DDE;"></span>
        <span class="theme-meta">
            <span class="theme-name">Aqua Claro</span>
            <span class="theme-desc">Azul limpio y luminoso</span>
        </span>
        <span class="theme-check">&#10003;</span>
    </button>

    <button type="button" class="theme-option" data-theme="dark">
        <span class="theme-swatch" style="background: linear-gradient(135deg,#111,#000); --sw-accent:#FF204E;"></span>
        <span class="theme-meta">
            <span class="theme-name">Oscuro Rojo</span>
            <span class="theme-desc">Estilo street de gimnasio</span>
        </span>
        <span class="theme-check">&#10003;</span>
    </button>

    <button type="button" class="theme-option" data-theme="midnight">
        <span class="theme-swatch" style="background: linear-gradient(135deg,#10213b,#0a1628); --sw-accent:#4d9fff;"></span>
        <span class="theme-meta">
            <span class="theme-name">Medianoche Azul</span>
            <span class="theme-desc">Oscuro con acento azul</span>
        </span>
        <span class="theme-check">&#10003;</span>
    </button>

    <p class="settings-section-title">Cuenta</p>
    <div class="settings-account">
        @if (SignInManager.IsSignedIn(User))
        {
            <div class="settings-user">
                <span class="settings-avatar">@(User.Identity?.Name?.Substring(0, 1).ToUpper())</span>
                <div style="min-width:0;">
                    <div class="settings-user-name">@User.Identity?.Name</div>
                    <div class="settings-user-sub">Sesión iniciada</div>
                </div>
            </div>
            <a class="btn-side btn-side-ghost" asp-area="Identity" asp-page="/Account/Manage/Index">Gestionar cuenta</a>
            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                <button type="submit" class="btn-side btn-side-primary">Cerrar sesión</button>
            </form>
        }
        else
        {
            <a class="btn-side btn-side-primary" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
            <a class="btn-side btn-side-ghost" asp-area="Identity" asp-page="/Account/Register">Crear cuenta</a>
        }
    </div>
</aside>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
