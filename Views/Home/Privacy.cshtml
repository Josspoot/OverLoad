@{
    ViewData["Title"] = "Librería";
}

<div class="page-wrapper" style="min-height: 90vh; display: flex; flex-direction: column; justify-content: flex-start; padding-top: 40px;">
    
    <div class="bg-watermark" style="top: 25%;">LIBRARY</div>

    <div class="container content-container">
        
        <div class="text-center mb-5">
            <h1 class="display-giant" style="font-size: 7vw; line-height: 0.85; text-shadow: 0 25px 50px rgba(0,0,0,0.9); margin-bottom: 20px;">
                @ViewData["Title"]
            </h1>
            <p class="mx-auto" style="font-family: var(--font-body); font-size: 1.2rem; font-weight: 300; color: #888; max-width: 650px;">
                Encuentra una cantidad de ejercicios los cuales pueden ser de utilidad para ti. Explora las variantes por grupo muscular.
            </p>
        </div>

        <div class="street-card mx-auto" style="max-width: 1200px;">
            <span class="card-badge">Catalog</span>
            <h3 style="font-size: 2.2rem; margin-bottom: 20px;">Lista por músculo</h3>
            
            <div class="row g-5">
                
                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Pecho</h4>
                    <div class="exercise-row">Press de banca plano</div>
                    <div class="exercise-row">Press de banca inclinado</div>
                    <div class="exercise-row">Press de banca declinado</div>
                    <div class="exercise-row">Flexiones de pecho (Push-ups)</div>
                    <div class="exercise-row">Aperturas con mancuernas</div>
                    <div class="exercise-row">Cruces en polea alta</div>
                    <div class="exercise-row">Cruces en polea baja</div>
                    <div class="exercise-row">Fondos en paralelas (Dips)</div>
                    <div class="exercise-row">Pullover con mancuerna</div>
                    <div class="exercise-row">Press en máquina convergente</div>
                </div>
                
                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Espalda</h4>
                    <div class="exercise-row">Dominadas (Pull-ups)</div>
                    <div class="exercise-row">Dominadas supinas (Chin-ups)</div>
                    <div class="exercise-row">Remo con barra pesado</div>
                    <div class="exercise-row">Remo en punta (T-Bar Row)</div>
                    <div class="exercise-row">Jalón al pecho agarre amplio</div>
                    <div class="exercise-row">Jalón al pecho agarre cerrado</div>
                    <div class="exercise-row">Remo con mancuerna a una mano</div>
                    <div class="exercise-row">Pullover en polea alta</div>
                    <div class="exercise-row">Peso muerto tradicional</div>
                    <div class="exercise-row">Hiperextensiones lumbares</div>
                </div>

                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Piernas</h4>
                    <div class="exercise-row">Sentadilla libre con barra</div>
                    <div class="exercise-row">Sentadilla frontal</div>
                    <div class="exercise-row">Sentadilla Búlgara</div>
                    <div class="exercise-row">Prensa de piernas (Leg Press)</div>
                    <div class="exercise-row">Peso muerto rumano (RDL)</div>
                    <div class="exercise-row">Zancadas con mancuernas (Lunges)</div>
                    <div class="exercise-row">Hip Thrust con barra</div>
                    <div class="exercise-row">Extensiones de cuádriceps</div>
                    <div class="exercise-row">Curl de isquios (Acostado o Sentado)</div>
                    <div class="exercise-row">Elevación de talones (Pantorrillas)</div>
                </div>

                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Hombros</h4>
                    <div class="exercise-row">Press militar con barra</div>
                    <div class="exercise-row">Press Arnold con mancuernas</div>
                    <div class="exercise-row">Elevaciones laterales</div>
                    <div class="exercise-row">Elevaciones frontales</div>
                    <div class="exercise-row">Pájaros (Rear delt fly)</div>
                    <div class="exercise-row">Face pulls en polea</div>
                    <div class="exercise-row">Remo al cuello (Upright row)</div>
                    <div class="exercise-row">Encogimientos de hombros (Shrugs)</div>
                    <div class="exercise-row">Press Bradford</div>
                </div>

                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Brazos</h4>
                    <div class="exercise-row">Curl de bíceps con barra Z</div>
                    <div class="exercise-row">Curl martillo con mancuernas</div>
                    <div class="exercise-row">Curl araña (Spider curl)</div>
                    <div class="exercise-row">Curl predicador en banco</div>
                    <div class="exercise-row">Extensiones de tríceps en polea</div>
                    <div class="exercise-row">Press francés con barra Z</div>
                    <div class="exercise-row">Rompecráneos (Skullcrushers)</div>
                    <div class="exercise-row">Fondos de tríceps en banco</div>
                    <div class="exercise-row">Patada de tríceps (Kickbacks)</div>
                </div>

                <div class="col-md-4 muscle-section mt-4">
                    <h4 class="muscle-title">Core</h4>
                    <div class="exercise-row">Plancha isométrica (Plank)</div>
                    <div class="exercise-row">Crunches en polea alta</div>
                    <div class="exercise-row">Elevación de piernas colgado</div>
                    <div class="exercise-row">Rueda abdominal (Ab wheel)</div>
                    <div class="exercise-row">Giros rusos (Russian twist)</div>
                    <div class="exercise-row">Woodchoppers en polea</div>
                    <div class="exercise-row">Dragon flags</div>
                    <div class="exercise-row">Toques de talón (Heel touches)</div>
                    <div class="exercise-row">Bicicletas abdominales</div>
                </div>

            </div>
        </div>
        
        <div class="text-center mt-5">
            <a asp-controller="Home" asp-action="Index" class="btn-update-street d-inline-block" style="padding: 10px 30px; font-size: 1.1rem;">
                Volver al Cuartel
            </a>
        </div>

    </div>
</div>