@using OverLoad.Application.Libreria
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@model IReadOnlyList<GrupoEjercicios>

@{
    ViewData["Title"] = "Librería";
}

<div class="page-wrapper" style="min-height: 90vh; padding-top: 40px;">

    <div class="bg-watermark" style="top: 25%;">LIBRARY</div>

    <div class="container content-container">

        <div class="text-center mb-5">
            <h1 class="display-giant" style="font-size: 7vw; line-height: 0.85; text-shadow: 0 25px 50px rgba(0,0,0,0.9); margin-bottom: 20px;">
                @ViewData["Title"]
            </h1>
            <p class="mx-auto" style="font-family: var(--font-body); font-size: 1.2rem; font-weight: 300; color: #888; max-width: 650px;">
                Explora los ejercicios por grupo muscular. Haz click en cualquiera para ver cómo hacerlo,
                qué debes sentir, recomendaciones y el equipo extra que conviene usar.
            </p>

            <div class="mt-4">
                @if (SignInManager.IsSignedIn(User))
                {
                    <a asp-controller="Libreria" asp-action="Nueva" class="btn-pill-red d-inline-block" style="padding: 10px 28px; font-size: 1.05rem;">+ Añadir ejercicio</a>
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-update-street d-inline-block" style="padding: 10px 28px;">Inicia sesión para añadir tus ejercicios</a>
                }
            </div>
        </div>

        @if (TempData["LibreriaMensaje"] is string libMsg)
        {
            <div class="alert-street mx-auto mb-4" style="max-width: 1200px;">@libMsg</div>
        }

        <div class="street-card mx-auto" style="max-width: 1200px;">
            <span class="card-badge">Catalog</span>
            <h3 style="font-size: 2.2rem; margin-bottom: 20px;">Lista por músculo</h3>

            <div class="row g-5">
                @foreach (var grupo in Model)
                {
                    <div class="col-md-4 muscle-section mt-4">
                        <h4 class="muscle-title">@grupo.Nombre</h4>
                        @foreach (var ej in grupo.Ejercicios)
                        {
                            <button type="button" class="ejercicio-item"
                                    data-bs-toggle="modal" data-bs-target="#ejercicioModal"
                                    data-slug="@ej.Slug"
                                    data-nombre="@ej.Nombre"
                                    data-grupo="@ej.Grupo"
                                    data-como="@ej.ComoHacerlo"
                                    data-sentir="@ej.QueSeDebeSentir"
                                    data-reco="@ej.Recomendaciones"
                                    data-equipo="@ej.EquipoExtra">
                                <span class="ejercicio-thumb">
                                    <img src="~/img/ejercicios/@(ej.Slug).jpg" alt="@ej.Nombre"
                                         loading="lazy"
                                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                                    <span class="ejercicio-thumb-ph">
                                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M6.5 6.5l11 11M21 21l-1-1M3 3l1 1M18 22l4-4M2 6l4-4M3 7l4 4M17 13l4 4"/>
                                        </svg>
                                    </span>
                                </span>
                                <span class="ejercicio-nombre">@ej.Nombre</span>
                                <span class="ejercicio-arrow">›</span>
                            </button>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="text-center mt-5">
            <a asp-controller="Home" asp-action="Index" class="btn-update-street d-inline-block" style="padding: 10px 30px; font-size: 1.1rem;">
                Volver al Cuartel
            </a>
        </div>

    </div>
</div>

<!-- MODAL DE DETALLE DEL EJERCICIO -->
<div class="modal fade" id="ejercicioModal" tabindex="-1" aria-labelledby="ejercicioModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content ejercicio-modal">
            <div class="modal-header">
                <div>
                    <span class="card-badge" id="m-grupo">Grupo</span>
                    <h5 class="modal-title mt-2" id="ejercicioModalLabel">Ejercicio</h5>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="ejercicio-modal-img mb-4">
                    <img id="m-img" src="" alt=""
                         onerror="this.style.display='none'; document.getElementById('m-img-ph').style.display='flex';">
                    <div id="m-img-ph" class="ejercicio-modal-ph">
                        <svg viewBox="0 0 24 24" width="46" height="46" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M6.5 6.5l11 11M21 21l-1-1M3 3l1 1M18 22l4-4M2 6l4-4M3 7l4 4M17 13l4 4"/>
                        </svg>
                        <span>Imagen descriptiva</span>
                    </div>
                </div>

                <div class="detalle-bloque">
                    <h6>Cómo hacerlo</h6>
                    <p id="m-como"></p>
                </div>
                <div class="detalle-bloque">
                    <h6>Qué se debe sentir</h6>
                    <p id="m-sentir"></p>
                </div>
                <div class="detalle-bloque">
                    <h6>Recomendaciones</h6>
                    <p id="m-reco"></p>
                </div>
                <div class="detalle-bloque detalle-equipo">
                    <h6>Equipo extra</h6>
                    <p id="m-equipo"></p>
                </div>
            </div>
            @if (SignInManager.IsSignedIn(User))
            {
                <div class="modal-footer border-0">
                    <form asp-controller="Home" asp-action="AgregarDesdeLibreria" method="post" class="w-100">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="nombre" id="m-tracker-nombre" />
                        <input type="hidden" name="grupo" id="m-tracker-grupo" />
                        <button type="submit" class="btn-pill-red w-100" style="padding: 12px 0;">+ Añadir al Tracker</button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('ejercicioModal').addEventListener('show.bs.modal', function (event) {
            const b = event.relatedTarget;
            const slug = b.getAttribute('data-slug');

            document.getElementById('ejercicioModalLabel').textContent = b.getAttribute('data-nombre');
            document.getElementById('m-grupo').textContent = b.getAttribute('data-grupo');
            document.getElementById('m-como').textContent = b.getAttribute('data-como');
            document.getElementById('m-sentir').textContent = b.getAttribute('data-sentir');
            document.getElementById('m-reco').textContent = b.getAttribute('data-reco');
            document.getElementById('m-equipo').textContent = b.getAttribute('data-equipo');

            const tNombre = document.getElementById('m-tracker-nombre');
            const tGrupo = document.getElementById('m-tracker-grupo');
            if (tNombre) { tNombre.value = b.getAttribute('data-nombre'); }
            if (tGrupo) { tGrupo.value = b.getAttribute('data-grupo'); }

            const img = document.getElementById('m-img');
            const ph = document.getElementById('m-img-ph');
            img.style.display = '';
            ph.style.display = 'none';
            img.alt = b.getAttribute('data-nombre');
            img.src = '/img/ejercicios/' + slug + '.jpg';
        });
    </script>
}
