@model IEnumerable<OverLoad.Models.Ejercicio>

@{
ViewData["Title"] = "Tracker";
}

<div class="page-wrapper">
    <div class="bg-watermark">PROGRESS</div>

    <div class="container content-container">
        <h1 class="display-1 fw-bold mb-5" style="font-size: 5.5rem;">Trackea tu progreso con nosotros</h1>

        <div class="street-card mb-5">
            <span class="card-badge">Input</span>
            <h5 class="mb-4" style="font-size: 2rem; color: var(--accent-red);">Añadir Ejercicio</h5>

            <form asp-controller="Home" asp-action="Crear" method="post" class="row g-4 align-items-end">
                <div class="col-md-3">
                    <label class="street-label">Nombre</label>
                    <input type="text" name="Nombre" class="form-control street-input" placeholder="Ej. Peso Muerto" required>
                </div>
                <div class="col-md-2">
                    <label class="street-label">Área de enfoque</label>
                    <select name="Enfoque" class="form-select street-select" required>
                        <option value="" style="color: black;">Selecciona...</option>
                        <option value="Pecho" style="color: black;">Pecho</option>
                        <option value="Espalda" style="color: black;">Espalda</option>
                        <option value="Piernas" style="color: black;">Piernas</option>
                        <option value="Hombros" style="color: black;">Hombros</option>
                        <option value="Brazos" style="color: black;">Brazos</option>
                        <option value="Core" style="color: black;">Core</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="street-label">Series</label>
                    <input type="number" name="Series" class="form-control street-input text-center text-white" min="1" required>
                </div>
                <div class="col-md-1">
                    <label class="street-label">Reps</label>
                    <input type="number" name="Repeticiones" class="form-control street-input text-center text-white" min="1" required>
                </div>
                <div class="col-md-2">
                    <label class="street-label">Peso (kg)</label>
                    <input type="number" step="0.5" name="Peso" class="form-control street-input text-center text-white" min="0" required>
                </div>
                <div class="col-md-2">
                    <label class="street-label">Esfuerzo (1-10)</label>
                    <input type="number" name="Esfuerzo" class="form-control street-input text-center text-white" min="1" max="10" required>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn-pill-red w-100" style="padding: 12px 0;">Añadir</button>
                </div>
            </form>
        </div>

        <h3 class="display-3 mb-4">Tus Ejercicios</h3>

        @if (Model == null || !Model.Any())
        {
        <div class="street-card p-4 text-center text-white-50" style="font-size: 1.1rem;">
            No hay ejercicios registrados. ¡Añade uno arriba!
        </div>
        }
        else
        {
        <div class="table-responsive street-table-wrapper">
            <table class="table street-table align-middle">
                <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Enfoque</th>
                    <th class="text-center">Series x Reps</th>
                    <th>Último Peso</th>
                    <th class="text-center">Nueva Carga</th>
                    <th>Acciones</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var ejercicio in Model)
                {
                <tr>
                    <td class="fw-bold text-white" style="font-size: 1.4rem;">@ejercicio.Nombre</td>

                    <td><span class="badge border border-light text-white bg-transparent" style="letter-spacing: 0.5px; font-weight: 600;">@ejercicio.Enfoque</span></td>

                    <td class="fw-bold text-white text-center" style="font-size: 1.6rem;">
                        @ejercicio.Series <span style="color: var(--accent-red); margin: 0 12px; font-size: 1.8rem; vertical-align: middle;">x</span> @ejercicio.Repeticiones
                    </td>

                    <td style="font-size: 1.6rem; color: var(--accent-red); font-weight: 800;">
                        @ejercicio.Peso <span style="font-size: 0.9rem; color: rgba(255,255,255,0.4); font-weight: 500; margin-left: 2px;">kg</span>
                    </td>

                    <td>
                        <form asp-controller="Home" asp-action="NuevaCarga" method="post" class="d-flex gap-2 align-items-center justify-content-center">
                            <input type="hidden" name="id" value="@ejercicio.Id" />

                            <input type="number" name="nuevasSeries" class="form-control street-input form-control-sm text-center fw-bold text-white" value="@ejercicio.Series" style="width: 55px" min="1" required>
                            <span style="color: var(--accent-red); font-weight: bold;">x</span>
                            <input type="number" name="nuevasRepeticiones" class="form-control street-input form-control-sm text-center fw-bold text-white" value="@ejercicio.Repeticiones" style="width: 55px" min="1" required>

                            <span style="color: rgba(255,255,255,0.2); font-weight: bold; margin: 0 5px;">|</span>
                            <input type="number" step="0.5" name="nuevoPeso" class="form-control street-input form-control-sm text-center fw-bold text-white" value="@ejercicio.Peso" style="width: 65px" min="0" required>
                            <span class="text-white-50" style="font-size: 0.8rem;">kg</span>

                            <button type="submit" class="btn-update-street ms-3">Actualizar</button>
                        </form>
                    </td>

                    <td>
                        <form asp-controller="Home" asp-action="Eliminar" method="post" onsubmit="return confirm('¿Estás seguro de que deseas eliminar @ejercicio.Nombre? Esta acción no se puede deshacer.');">
                            <input type="hidden" name="id" value="@ejercicio.Id" />
                            <button type="submit" class="btn-delete-street">Eliminar</button>
                        </form>
                    </td>
                </tr>
                }
                </tbody>
            </table>
        </div>
        }
    </div>
</div>