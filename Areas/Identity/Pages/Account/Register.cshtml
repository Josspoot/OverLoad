@page
@model RegisterModel
@{
    ViewData["Title"] = "Crear cuenta";
}

<div class="page-wrapper auth-wrap">
    <div class="bg-watermark">JOIN</div>

    <div class="auth-card">
        <span class="auth-badge">Nuevo</span>
        <h1 class="auth-title">Crea tu cuenta</h1>
        <p class="auth-sub">Regístrate y entra directo a entrenar. Sin pasos extra.</p>

        <form id="registerForm" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <div class="auth-field">
                <label asp-for="Input.Email">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username"
                       aria-required="true" placeholder="tucorreo@ejemplo.com"/>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="new-password"
                       aria-required="true" placeholder="Mínimo 6 caracteres"/>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password"
                       aria-required="true" placeholder="Repite la contraseña"/>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn-pill-red auth-submit">Crear cuenta e iniciar</button>
        </form>

        <p class="auth-alt">
            ¿Ya tienes cuenta?
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Inicia sesión</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
