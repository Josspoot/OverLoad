@page
@model LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="page-wrapper auth-wrap">
    <div class="bg-watermark">LOGIN</div>

    <div class="auth-card">
        <span class="auth-badge">Bienvenido</span>
        <h1 class="auth-title">Inicia sesión</h1>
        <p class="auth-sub">Entra para acceder a tu Tracker, Librería y Bitácora.</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="auth-error" role="alert"></div>

            <div class="auth-field">
                <label asp-for="Input.Email">Correo electrónico</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username"
                       aria-required="true" placeholder="tucorreo@ejemplo.com"/>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="auth-field">
                <label asp-for="Input.Password">Contraseña</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                       aria-required="true" placeholder="••••••••"/>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <label class="auth-check">
                <input class="form-check-input" asp-for="Input.RememberMe"/> @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>

            <button id="login-submit" type="submit" class="btn-pill-red auth-submit">Entrar</button>
        </form>

        <p class="auth-alt">
            ¿No tienes cuenta?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Crea una cuenta</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
